# Example configuration for MobileTask.
# Copy this file to .env.local and adjust the host for your environment.

# Local Node.js backend:
EXPO_PUBLIC_BACKEND_HOST=localhost
EXPO_PUBLIC_BACKEND_PORT=8000
EXPO_PUBLIC_BACKEND_PROTOCOL=http

# For a physical mobile device, replace localhost with your computer LAN IP.
# Example:
# EXPO_PUBLIC_BACKEND_HOST=192.168.1.100
